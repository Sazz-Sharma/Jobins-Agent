# ── Groq Configuration ───────────────────────────────────────
# Your Groq API key (required)
GROQ_API_KEY=gsk-your-key-here

# Model to use (Qwen 3 32B on Groq)
GROQ_MODEL=qwen/qwen3-32b

# ── Budget Constraints ───────────────────────────────────────
# Maximum number of LLM calls per task (hard limit)
MAX_LLM_CALLS=10

# Maximum simulated cost in USD per task (hard limit)
# Uses mock pricing: $0.00075/1k input, $0.0045/1k output
MAX_BUDGET_USD=0.20
